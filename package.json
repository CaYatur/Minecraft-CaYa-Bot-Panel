{
  "name": "caya-bot-panel",
  "version": "1.0.2",
  "private": true,
  "license": "MIT",
  "author": "ÇAĞAN TURGUT (CaYatur)",
  "description": "Minecraft CaYa Bot Panel - multi-bot control panel (mineflayer)",
  "main": "electron/main.cjs",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"npm run dev -w server\" \"npm run dev -w web\"",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w server && npm run build -w web",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "testserver": "node test-server/start.cjs",
    "smoke": "node scripts/smoke.mjs",
    "test:combat": "node scripts/combat-test.mjs",
    "test:full": "node scripts/full-suite.mjs",
    "test:grok": "node scripts/grok-smoke-all.mjs",
    "test:all": "node scripts/combat-test.mjs && node scripts/full-suite.mjs && node scripts/smoke.mjs && node scripts/movement-test.mjs && node scripts/inventory-test.mjs && node scripts/grok-smoke-all.mjs",
    "electron:dev": "electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "express": "^4.21.0",
    "minecraft-data": "^3.111.0",
    "mineflayer": "^4.20.0",
    "mineflayer-armor-manager": "^2.0.1",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-tool": "^1.2.0",
    "prismarine-nbt": "^2.8.0",
    "prismarine-schematic": "^1.3.0",
    "socket.io": "^4.7.5",
    "vec3": "^0.1.10"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "flying-squid": "^1.12.0"
  },
  "build": {
    "appId": "com.cayadev.caya-bot-panel",
    "productName": "Minecraft CaYa Bot Panel",
    "copyright": "Copyright © 2026 CaYatur",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "server/dist/**/*",
      "web/dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
